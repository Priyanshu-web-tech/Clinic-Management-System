MONGODB_URI=your_mongodb_connection_string

PORT=3000
NODE_ENV=development

# Cookie & Token
COOKIE_SECRET=your_random_cookie_secret
TOKEN_EXPIRES_IN=1d
REFRESH_TOKEN_EXPIRES_IN=7d

# JWT (RS256 — requires private.key / public.key files)
SECRET_KEY=your_secret_key
JWT_ALGO=RS256
JWT_ISSUER=DOCMATE
ROUND=10

# Email (for OTP delivery via Brevo)
BREVO_API_KEY=your_brevo_api_key
BREVO_SENDER_EMAIL=your_sender_email@example.com

# Cron job secret (used to authenticate scheduled cron requests)
CRON_SECRET=your_cron_secret

# OTP
OTP_EXPIRES_IN=15m
OTP_DIGIT=6
OTP_BYPASS=false
# OTP=999666   # Uncomment to use a fixed bypass OTP in development

# CORS
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:3000

# Server redirect (used for OAuth / redirects)
SERVER_REDIRECT_URI=http://localhost:3000
